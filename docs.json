    "primary": "#18181B",
    "light": "#52525B",
    "dark": "#FAFAFA"
  },
  "font": {
    "headings": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "layout": "topnav",
  "rounded": "default",
