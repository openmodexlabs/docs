    "links": [
      {
        "label": "Website",
        "href": "https://openmodex.com"
      },
      {
        "label": "Dashboard",
        "href": "https://openmodex.com/dashboard"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://openmodex.com/dashboard/api-keys"
    }
  },
